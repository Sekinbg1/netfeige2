<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:descendantFocusability="blocksDescendants"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:gravity="right"
        android:orientation="horizontal"
        android:id="@+id/content_llayout_messageitemto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="10dp"
        android:layout_alignParentRight="true">
        <LinearLayout
            android:gravity="center"
            android:layout_gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/operate_layout_messageitemto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="10dp"
            android:layout_weight="1">
            <Button
                android:textColor="@color/white"
                android:id="@+id/resend_btn_messageitemto"
                android:background="@drawable/x_file_tran_btn"
                android:paddingLeft="3dp"
                android:paddingRight="3dp"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/resend"/>
        </LinearLayout>
        <LinearLayout
            android:orientation="vertical"
            android:background="@drawable/msg_item_to_bg"
            android:paddingLeft="10dp"
            android:paddingTop="10dp"
            android:paddingRight="20dp"
            android:paddingBottom="10dp"
            android:layout_width="200dp"
            android:layout_height="wrap_content">
            <TextView
                android:id="@+id/content_text_messageitemto"
                android:maxWidth="200dp"
                style="@style/textview_small"/>
            <TextView
                android:id="@+id/date_text_messageitemto"
                style="@style/textview_small"/>
            <TextView
                android:id="@+id/prompt_text_messageitemto"
                android:visibility="gone"
                style="@style/textview_small"/>
        </LinearLayout>
    </LinearLayout>
    <ImageView
        android:id="@+id/status_img_messageitemto"
        android:layout_toLeftOf="@+id/content_llayout_messageitemto"
        android:layout_alignTop="@+id/content_llayout_messageitemto"
        style="@style/imageview"/>
</RelativeLayout>
