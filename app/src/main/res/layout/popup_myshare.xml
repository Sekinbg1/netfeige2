<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:id="@+id/linearl_popup_myshare"
    android:background="@drawable/popup2"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/add_linearl_popup_myshare"
        android:layout_width="131dp"
        android:layout_height="40dp"
        android:layout_marginTop="5dp">
        <ImageView
            android:id="@+id/add_imgv_popup_myshare"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="13dp"
            android:src="@drawable/addshare"/>
        <TextView
            android:textColor="@color/white"
            android:id="@+id/add_textv_popup_myshare"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="17dp"
            android:text="@string/addshare"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/pwd_linearl_popup_myshare"
        android:layout_width="131dp"
        android:layout_height="40dp"
        android:layout_marginTop="1dp">
        <ImageView
            android:id="@+id/pwd_imgv_popup_myshare"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="13dp"
            android:src="@drawable/sharepwd"/>
        <TextView
            android:textColor="@color/white"
            android:id="@+id/pwd_textv_popup_myshare"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="17dp"
            android:text="@string/sharepwd"/>
    </LinearLayout>
</LinearLayout>
