<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:background="@color/white"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/top_navigation_layout_chat"
            android:background="@drawable/bg_top_navigation_bar"
            android:layout_width="match_parent"
            android:layout_height="48dp">
            <Button
                android:id="@+id/back_btn_chat"
                android:background="@drawable/x_back"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="6dp"/>
            <TextView
                android:gravity="center"
                android:id="@+id/title_text_chat"
                android:layout_weight="1"
                style="@style/textview_large"/>
            <Button
                android:id="@+id/delete_btn_chat"
                android:background="@drawable/x_delete"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="6dp"/>
        </LinearLayout>
        <ListView
            android:id="@+id/message_list_chat"
            android:background="@color/white"
            android:paddingBottom="10dp"
            android:fadingEdge="none"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:transcriptMode="alwaysScroll"
            android:cacheColorHint="#00000000"
            android:divider="#00000000"
            android:dividerHeight="0px"
            android:layout_weight="1"/>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/send_layout_chat"
            android:background="@drawable/send_bg"
            android:layout_width="match_parent"
            android:layout_height="62dp">
            <Button
                android:id="@+id/face_btn_chat"
                android:background="@drawable/x_face"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="6dp"/>
            <Button
                android:id="@+id/file_btn_chat"
                android:background="@drawable/x_file_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="6dp"/>
            <EditText
                android:id="@+id/input_edittext_chat"
                android:background="@drawable/msg_edittext"
                android:paddingLeft="3dp"
                android:paddingRight="3dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="5dp"
                android:layout_marginRight="5dp"
                android:layout_weight="1"/>
            <Button
                android:textColor="@color/white"
                android:id="@+id/send_btn_chat"
                android:background="@drawable/x_send_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="6dp"
                android:text="@string/send"/>
        </LinearLayout>
        <GridView
            android:id="@+id/face_gridView_chat"
            android:background="#f5f6f7"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:cacheColorHint="#f5f6f7"
            android:horizontalSpacing="10dp"
            android:verticalSpacing="10dp"
            android:stretchMode="columnWidth"
            android:columnWidth="36dp"
            android:numColumns="auto_fit"/>
        <com.netfeige.display.ui.SendFileLinearLayout
            android:id="@+id/linearlayout_popwindow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
    </LinearLayout>
</FrameLayout>
