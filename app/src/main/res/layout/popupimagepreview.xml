<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:id="@+id/linearl_popup"
    android:background="@drawable/popup3"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/linearl_send"
        android:layout_width="111dp"
        android:layout_height="40dp"
        android:layout_marginTop="5dp">
        <ImageView
            android:id="@+id/imagev_send"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="13dp"
            android:src="@drawable/popupsend2"/>
        <TextView
            android:textColor="@color/white"
            android:id="@+id/textv_send"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="17dp"
            android:text="@string/send"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/linearl_screeninteract"
        android:layout_width="111dp"
        android:layout_height="40dp"
        android:layout_marginTop="1dp">
        <ImageView
            android:id="@+id/imagev_screeninteract"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="13dp"
            android:src="@drawable/mulscreen"/>
        <TextView
            android:textColor="@color/white"
            android:id="@+id/textv_screeninteract"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="17dp"
            android:text="@string/startscreeninteraction"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/linearl_print"
        android:layout_width="111dp"
        android:layout_height="40dp"
        android:layout_marginTop="1dp">
        <ImageView
            android:id="@+id/imagev_print"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="13dp"
            android:src="@drawable/print_query"/>
        <TextView
            android:textColor="@color/white"
            android:id="@+id/textv_print"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="17dp"
            android:text="@string/print"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/linearl_share"
        android:layout_width="111dp"
        android:layout_height="40dp"
        android:layout_marginTop="1dp">
        <ImageView
            android:id="@+id/imagev_share"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="13dp"
            android:src="@drawable/share"/>
        <TextView
            android:textColor="@color/white"
            android:id="@+id/textv_share"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="17dp"
            android:text="@string/share"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/linearl_delete"
        android:layout_width="111dp"
        android:layout_height="40dp"
        android:layout_marginTop="1dp">
        <ImageView
            android:id="@+id/imagev_delete"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="13dp"
            android:src="@drawable/print_delete"/>
        <TextView
            android:textColor="@color/white"
            android:id="@+id/textv_delete"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="17dp"
            android:text="@string/delete"/>
    </LinearLayout>
</LinearLayout>
