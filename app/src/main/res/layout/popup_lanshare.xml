<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:id="@+id/linearl_popup_lanshare"
    android:background="@drawable/popup2"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/home_linearl_popup_lanshare"
        android:layout_width="120dp"
        android:layout_height="40dp"
        android:layout_marginTop="5dp">
        <ImageView
            android:id="@+id/home_imgv_popup_lanshare"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="13dp"
            android:src="@drawable/sendout"/>
        <TextView
            android:textColor="@color/white"
            android:id="@+id/home_textv_popup_lanshare"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="17dp"
            android:text="@string/home"/>
    </LinearLayout>
</LinearLayout>
