<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/white"
    android:descendantFocusability="blocksDescendants"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="horizontal"
        android:paddingLeft="10dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="16sp"
            android:textColor="@color/black"
            android:gravity="center"
            android:layout_gravity="center_vertical"
            android:id="@+id/name_text_wtitem"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:layout_margin="5dp"/>
        <LinearLayout
            android:gravity="center"
            android:layout_gravity="center_vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="10dp"
            android:layout_weight="1">
            <TextView
                android:textSize="14sp"
                android:textColor="@color/drap_bar_word_color"
                android:gravity="center"
                android:layout_gravity="center_vertical"
                android:id="@+id/connect_text_wtitem"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:text="@string/connect"/>
            <LinearLayout
                android:orientation="horizontal"
                android:id="@+id/connect_ok_layout_wtitem"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <ImageView
                    android:id="@+id/connect_ok_image_wtitem"
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:src="@drawable/wt_connect_ok"
                    android:scaleType="centerInside"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/drap_bar_word_color"
                    android:gravity="center"
                    android:layout_gravity="center_vertical"
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:text="@string/disconnect"
                    android:singleLine="true"/>
            </LinearLayout>
            <ProgressBar
                android:id="@+id/connecting_progressBar_wtitem"
                android:visibility="gone"
                android:layout_width="30dp"
                android:layout_height="30dp"
                style="@android:attr/progressBarStyleSmall"/>
        </LinearLayout>
    </LinearLayout>
    <View
        android:background="#cccccc"
        android:layout_width="match_parent"
        android:layout_height="1dp"/>
</LinearLayout>
