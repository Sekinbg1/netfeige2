<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:id="@+id/linearl_popup"
    android:background="@drawable/popup"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/linearl_newbuild"
        android:layout_width="111dp"
        android:layout_height="40dp"
        android:layout_marginTop="5dp">
        <ImageView
            android:id="@+id/imagev_newbuild"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="13dp"
            android:src="@drawable/newbuild"/>
        <TextView
            android:textColor="@color/white"
            android:id="@+id/textv_refresh"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="17dp"
            android:text="@string/new_build"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/linearl_sort"
        android:layout_width="111dp"
        android:layout_height="40dp"
        android:layout_marginTop="1dp">
        <ImageView
            android:id="@+id/imagev_sort"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="13dp"
            android:src="@drawable/sort"/>
        <TextView
            android:textColor="@color/white"
            android:id="@+id/textv_sort"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="17dp"
            android:text="@string/sort"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/linearl_backroot"
        android:layout_width="111dp"
        android:layout_height="40dp">
        <ImageView
            android:id="@+id/imagev_backroot"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="13dp"
            android:src="@drawable/backroot"/>
        <TextView
            android:textColor="@color/white"
            android:id="@+id/textv_backroot"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="17dp"
            android:text="@string/backroot"/>
    </LinearLayout>
</LinearLayout>
